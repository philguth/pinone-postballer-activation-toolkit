{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinball Cabinet Activation Profile",
  "type": "object",
  "required": ["profileName", "version", "controller", "outputs", "audio", "lighting"],
  "properties": {
    "profileName": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "controller": {
      "type": "object",
      "required": ["type", "connection"],
      "properties": {
        "type": { "type": "string" },
        "connection": { "type": "string" }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["outputNumber", "logicalName"],
        "properties": {
          "outputNumber": { "type": "integer" },
          "logicalName": { "type": "string" },
          "physicalLabel": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["logicalName"],
        "properties": {
          "logicalName": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "audio": {
      "type": "object",
      "required": ["mode", "channels"],
      "properties": {
        "mode": { "type": "string" },
        "channels": { "type": "string" }
      }
    },
    "lighting": {
      "type": "object",
      "properties": {
        "ledMatrix": { "type": "boolean" },
        "addressableStrips": { "type": "boolean" }
      }
    }
  }
}